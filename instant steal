-- --- PRECISE LOGIC ---
local currentPlot, currentPodium = nil, nil

RunService.RenderStepped:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local found = false
    local closestDist = 8
    local myPos = root.Position

    for _, plot in pairs(PlotsFolder:GetChildren()) do
        local pods = plot:FindFirstChild("AnimalPodiums")
        if pods then
            for _, pod in pairs(pods:GetChildren()) do
                local podPos = pod:GetPivot().Position
                local heightDiff = math.abs(myPos.Y - podPos.Y)
                
                -- Check height
                if heightDiff < 5 then
                    local dist = (Vector2.new(myPos.X, myPos.Z) - Vector2.new(podPos.X, podPos.Z)).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        currentPlot = plot.Name
                        currentPodium = tonumber(pod.Name) or pod.Name
                        infoLabel.Text = "PODIUM: " .. currentPodium
                        found = true
                    end
                end
            end
        end
        if found then break end
    end
    
    if not found then 
        infoLabel.Text = "Stand on brainrot"
        currentPlot, currentPodium = nil, nil
    end
end)

fireButton.MouseButton1Click:Connect(function()
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if currentPlot and currentPodium and hum then
        local args = {1776290224.694484, "579e6c26-5a80-407d-9488-0f84752e8f1f", currentPlot, currentPodium}
        
        
        hum.Health = 0
        task.wait(0.35)
        for i = 1, 3 do Remote:FireServer(unpack(args)) end
        
        
