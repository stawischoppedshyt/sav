local function Refresh()
    local ok, res = pcall(function() return game:HttpGet(FETCH_URL.."?t="..tick()) end)
    if ok then
        Status.Text = "connected"
        Status.TextColor3 = Color3.fromRGB(50, 180, 100)
        local data = HttpService:JSONDecode(res)
        
        for _, v in pairs(Container:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
        
        -- Reset active logs tracker for this tick
        activeLogs = {}
        
        for _, info in ipairs(data) do
            for _, pets in pairs(info.plots) do
                for _, pet in pairs(pets) do
                    
                    -- FUSE TICKET EXCLUSION: Skips the entry if the name contains "fuse ticket"
                    if not string.find(pet.name:lower(), "fuse ticket") then
                        local g = pet.gen:lower()
                        
                        -- RATE AND TIMER FILTER LOGIC
                        local isForbidden = string.find(g, "m") or string.find(g, ":") or string.match(g, "%d+s")
                        local isValidRate = string.find(g, "b") or string.find(g, "k") or string.find(g, "/s")

                        if isValidRate and not isForbidden then
                            -- Generate a unique ID for this specific log entry
                            local uniqueId = info.jobId .. "_" .. pet.name
                            
                            -- Only add it to the UI if it hasn't been cleared manually
                            if not clearedLogs[uniqueId] then
                                activeLogs[uniqueId] = true
                                AddLogEntry(info.jobId, pet.name, pet.gen)
                                
                                if autojoinEnabled then 
                                    pcall(function() TeleportService:TeleportToPlaceInstance(PLACE_ID, info.jobId, LP) end)
                                    return 
                                end
                            end
                        end
                    end
                end
            end
        end
    else
        Status.Text = "reconnecting..."
        Status.TextColor3 = Color3.fromRGB(200, 50, 50)
    end
end

-- CLEAR LOGS FIX: Adds current active logs to a hidden list so they don't respawn
